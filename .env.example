# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram User ID (from @userinfobot)
ADMIN_ID=your_telegram_user_id_here

# TronGrid API Key (free from trongrid.io)
TRONGRID_API_KEY=your_trongrid_api_key_here

# Your USDT (TRC20) Wallet Address (where users send USDT)
YOUR_USDT_WALLET=TYourWalletAddressHere

# Optional: Paystack API Key (for bank verification)
PAYSTACK_SECRET_KEY=your_paystack_key_here

# Optional: Your wallet's private key (for auto-sending USDT withdrawals)
YOUR_WALLET_PRIVATE_KEY=your_wallet_private_key_here
